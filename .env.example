# Database
DATABASE_URL="postgresql://posadmin:poslocal@localhost:5437/pos_saas?schema=public"

# Auth
# REQUIRED in production — generate with: openssl rand -base64 32
# The server refuses to boot in production if this is unset or a known placeholder.
AUTH_SECRET="dev-secret-change-in-production-use-openssl-rand-base64-32"
AUTH_URL="http://localhost:3007"
NEXTAUTH_URL="http://localhost:3007"

# Timezone — Indonesia-only app runs in WIB so dashboard/reporting day
# boundaries align with Jakarta midnight. (Set on the app container, not the db.)
TZ="Asia/Jakarta"

# Auth rate-limiting — ON by default. Set to "true" ONLY in dev/test containers
# that run many logins per minute from one IP (avoid false 429s).
RATE_LIMIT_DISABLED="false"

# Google Search Console verification — paste the content value from GSC
# (search.google.com/search-console → property → meta tag verification).
# When set, outputs <meta name="google-site-verification" content="...">.
GOOGLE_SITE_VERIFICATION=""

# Google OAuth (register at console.cloud.google.com)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Exposed to client bundle — also needed at BUILD time, not just runtime.
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED="true"

# Platform
PLATFORM_DOMAIN="localhost"

# Midtrans (leave empty for dev mode — checkout auto-succeeds without real Midtrans)
# Get sandbox keys at https://dashboard.sandbox.midtrans.com/settings/config_info
MIDTRANS_SERVER_KEY=""
MIDTRANS_CLIENT_KEY=""
MIDTRANS_ENV="sandbox"
# Exposed to client bundle — also needed at BUILD time, not just runtime.
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=""
NEXT_PUBLIC_MIDTRANS_ENV="sandbox"

# SMTP for support ticket email notifications (optional — best-effort, no-op if unset)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM="hivePOS Support <support@example.com>"

# Order proof photos — compressed WebP on local disk, auto-deleted after 7 days.
# Host path; in Docker a bind-mount maps ./data/uploads -> /app/data/uploads so
# the files sit plainly on the host (inspect/backup/clean without Docker tooling).
PHOTO_UPLOAD_DIR="./data/uploads"

# Shared secret authorizing the daily photo-cleanup cron
# (POST /api/internal/photo-cleanup). Leave empty to disable the endpoint
# (fail-closed). Generate: openssl rand -hex 32
CRON_SECRET=""
