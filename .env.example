# Database
DATABASE_URL="postgresql://posadmin:poslocal@localhost:5437/pos_saas?schema=public"

# Auth
AUTH_SECRET="dev-secret-change-in-production-use-openssl-rand-base64-32"
AUTH_URL="http://localhost:3007"
NEXTAUTH_URL="http://localhost:3007"

# Google OAuth (register at console.cloud.google.com)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Exposed to client bundle — also needed at BUILD time, not just runtime.
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED="true"

# Platform
PLATFORM_DOMAIN="localhost"

# Midtrans (leave empty for dev mode — checkout auto-succeeds without real Midtrans)
# Get sandbox keys at https://dashboard.sandbox.midtrans.com/settings/config_info
MIDTRANS_SERVER_KEY=""
MIDTRANS_CLIENT_KEY=""
MIDTRANS_ENV="sandbox"
# Exposed to client bundle — also needed at BUILD time, not just runtime.
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=""
NEXT_PUBLIC_MIDTRANS_ENV="sandbox"

# SMTP for support ticket email notifications (optional — best-effort, no-op if unset)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM="hivePOS Support <support@example.com>"
